# Copy this to .env and fill in your API key
# Only one key is needed — the backend tries them in order: Gemini → Groq → OpenRouter

# Google Gemini (free tier: https://ai.google.dev)
GEMINI_API_KEY=

# Groq (free tier: https://console.groq.com)
GROQ_API_KEY=

# OpenRouter (free models: https://openrouter.ai)
OPENROUTER_API_KEY=
